# -----------------------------
# Zabbix core stack
# -----------------------------
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=change_me_strong_password
PHP_TZ=Europe/Paris

# Host ports (change these if already used on your machine)
ZABBIX_WEB_PORT=8080
ZABBIX_SERVER_PORT=10051
ZABBIX_AGENT_PORT=10050

# Internal Zabbix DNS/service values
ZBX_SERVER_HOST=zabbix-server
ZBX_SERVER_ACTIVE=zabbix-server
ZBX_LOCAL_AGENT_HOSTNAME=Zabbix server
ENABLE_AUTOSCALE_STACK=false

# -----------------------------
# Auto-registration metadata
# -----------------------------
ZBX_METADATA_AGENT=agent
ZBX_METADATA_WEBAPI=webapi-linux
ZBX_METADATA_AUTOSCALE=autoscale-linux

# -----------------------------
# Application stack ports
# -----------------------------
APP_MACHINE1_WEB_PORT=8081
APP_MACHINE2_WEB_PORT=8082
APP_MACHINE3_WEB_PORT=8083

# Optional standalone API ports (docker-compose.yml)
USER_SERVICE_PORT=5003
PRODUCT_SERVICE_PORT=5002
ORDER_SERVICE_PORT=5001

# Optional hostnames exposed in Zabbix
MACHINE1_HOSTNAME=machine-1
MACHINE2_HOSTNAME=machine-2
MACHINE3_HOSTNAME=machine-3
